  "keyFeatures": [
    "Thread-based messaging with channels and spaces",
    "Voice, video, and screen sharing via LiveKit",
    "Real-time collaborative wiki editing with Y.js",
    "Bot API with JavaScript and Python SDKs",
    "Role-based permissions system",
    "Direct messages and group DMs",
    "Self-hostable with Docker Compose",
    "WebSocket-based real-time event system"
  ],
  "publicApiSurface": [
    "MikotoClient (mikoto.js)",
    "AuthClient / BotAuthClient (mikoto.js)",
    "SpaceManager: list, join, create",
    "ChannelManager: list, create, delete, sendMessage",
    "MessageManager: list, create, edit, delete",
    "MemberManager, RoleManager, RelationshipManager",
    "POST /account/login",
    "POST /account/register",
    "POST /account/refresh",
    "GET/POST/PATCH/DELETE /spaces",
    "GET/POST/PATCH/DELETE /spaces/:spaceId/channels",
    "GET/POST/PATCH/DELETE /spaces/:spaceId/channels/:channelId/messages",
    "GET/POST/PATCH/DELETE /bots",
    "POST /bots/login",
    "GET/POST/PATCH/DELETE /users",
    "WebSocket events: spaces.onCreate/onUpdate/onDelete, channels.onCreate/onUpdate/onDelete, messages.onCreate/onUpdate/onDelete, typing.onUpdate"
  ]
